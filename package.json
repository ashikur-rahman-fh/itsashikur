{
  "name": "ashikur-portfolio",
  "private": true,
  "scripts": {
    "typegen": "pnpm --filter @ashikur-portfolio/frontend-main --filter @ashikur-portfolio/frontend-admin run typegen",
    "preformat": "pnpm typegen",
    "format": "prettier . --write",
    "preformat:check": "pnpm typegen",
    "format:check": "prettier . --check",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm format && pnpm -r --if-present lint:fix",
    "fix": "pnpm format && pnpm -r --if-present lint:fix",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "bash infra/scripts/build/build-frontends.sh",
    "favicons:generate": "node infra/scripts/generate-favicons.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm python:check && pnpm python:migrations:check && pnpm audit --audit-level=high",
    "python:lint": "PATH=\"$PWD/apps/backend/.venv/bin:$PATH\" ruff check apps/backend",
    "python:lint:fix": "PATH=\"$PWD/apps/backend/.venv/bin:$PATH\" ruff check apps/backend --fix",
    "python:format": "PATH=\"$PWD/apps/backend/.venv/bin:$PATH\" ruff format apps/backend",
    "python:format:check": "PATH=\"$PWD/apps/backend/.venv/bin:$PATH\" ruff format apps/backend --check",
    "python:check": "pnpm python:format:check && pnpm python:lint",
    "python:migrations:check": "PATH=\"$PWD/apps/backend/.venv/bin:$PATH\" sh -c 'cd apps/backend && DJANGO_SETTINGS_MODULE=config.settings.dev python manage.py check && python manage.py makemigrations --check --dry-run'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.3"
  },
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  }
}
