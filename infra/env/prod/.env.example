PROJECT_NAME=ashikur-portfolio
# Docker Compose project name (container prefix). Keep stable after first deploy — changing it creates new volumes.
COMPOSE_PROJECT_NAME=ashikur-portfolio-prod
# Production (config.settings.prod): SECRET_KEY and POSTGRES_PASSWORD must be real secrets.
# Placeholders starting with "change-me" are rejected — Gunicorn workers will not start.
ENVIRONMENT=prod
DEBUG=false
SECRET_KEY=change-me-generate-strong-secret
DJANGO_SETTINGS_MODULE=config.settings.prod
# Keep `backend` and/or `127.0.0.1` in ALLOWED_HOSTS so deploy health checks from inside the container are not HTTP 400 (DisallowedHost).
ALLOWED_HOSTS=itsashikur.com,www.itsashikur.com,admin.itsashikur.com,api.itsashikur.com,backend,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://itsashikur.com,https://www.itsashikur.com,https://admin.itsashikur.com,https://api.itsashikur.com
CORS_ALLOWED_ORIGINS=https://itsashikur.com,https://www.itsashikur.com,https://admin.itsashikur.com

POSTGRES_DB=ashikur_portfolio_prod
POSTGRES_USER=ashikur
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

BACKEND_URL=https://api.itsashikur.com
# Browser-facing API URL (baked into Next at image build). Must be https:// and match your
# public API host — same origin as API_HOST with https, never http://backend:8000 or localhost.
NEXT_PUBLIC_BACKEND_MAIN_API_URL=https://api.itsashikur.com
NEXT_PUBLIC_CONTACT_EMAIL=me@itsashikur.com
NEXT_PUBLIC_BASE_PATH=

# Nginx vhosts (rendered into infra/nginx/prod/conf.d/default.conf via make prod-nginx-config)
MAIN_FRONTEND_HOST=itsashikur.com
MAIN_FRONTEND_WWW_HOST=www.itsashikur.com
ADMIN_FRONTEND_HOST=admin.itsashikur.com
API_HOST=api.itsashikur.com

# Registry deploy on the VM (make prod-deploy IMAGE_TAG=staging-260516-1)
# Copy the same values as GitHub Environment staging_env / release_env. Never commit real tokens.
DOCKER_REPO=yourorg/your-app-staging
BRANCH_SLUG=staging
DOCKER_USERNAME=
DOCKER_TOKEN=
BACKUP_DIR=/var/backups/ashikur-portfolio
# Public API host for health checks (defaults to API_HOST if unset)
APP_DOMAIN=api.itsashikur.com
# HEALTH_CHECK_HTTP_HOST=api.itsashikur.com
# HEALTH_CHECK_PATH=/api/health/

# Security (optional overrides)
# CLIENT_MAX_BODY_SIZE=25m
# DRF_THROTTLE_ANON=100/hour
# DRF_THROTTLE_API=200/hour
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_MINUTES=30
# DATA_UPLOAD_MAX_BYTES=2621440
# CSP_REPORT_ONLY=false
# CSP_REPORT_URI=
# GIT_REF=master
# SKIP_GIT_SYNC=1

WAIT_FOR_DEBUGGER=false

# Admin superusers (JSON array). Idempotent sync: make prod-sync-superusers
# ADMIN_SUPERUSERS='[{"username":"admin","email":"admin@example.com","password":"change-me-in-env","first_name":"Admin","last_name":"User"}]'
# ADMIN_SUPERUSER_UPDATE_PASSWORD=false
